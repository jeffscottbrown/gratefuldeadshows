---
/**
 * Collection detail page: /collections/daves-picks, /collections/dicks-picks, etc.
 *
 * Renders a grid of release cards. Sort (by date vs by volume) is handled
 * entirely by vanilla JS — no React island needed.
 */
import Layout from '@/components/Layout.astro';
import CollectionBadge from '@/components/CollectionBadge.astro';
import { getAllCollections, getReleasesByCollection } from '@/lib/releases';
import { getAllShows } from '@/lib/shows';
import { getBadge } from '@/lib/badges';
import { formatDate } from '@/lib/format';

export async function getStaticPaths() {
  const collections = await getAllCollections();
  return collections.map((c) => ({ params: { collection: c.slug } }));
}

const { collection: slug } = Astro.params;
const badge = getBadge(slug);
const [releases, allShows] = await Promise.all([
  getReleasesByCollection(slug),
  getAllShows(),
]);

// Build date → show slug map so we can link show dates
const showByDate = new Map(allShows.map((s) => [s.date, s]));

// Pre-sort both orders server-side; JS toggles visibility
const byDate   = [...releases].sort((a, b) => (a.dates[0] ?? a.startDate ?? '').localeCompare(b.dates[0] ?? b.startDate ?? ''));
const byVolume = [...releases].sort((a, b) => (a.volume ?? 999) - (b.volume ?? 999));
const hasVolumes = releases.some((r) => r.volume !== undefined);

// Are all releases linking to archive.org (Hunter's Trix) or DeadDisc?
const isArchive = slug === 'hunters-trix';
---

<Layout title={`${badge.name} Releases`}>
  <div class="mx-auto max-w-7xl px-4 py-10">
    <!-- Breadcrumb -->
    <div class="flex items-center gap-2 text-sm text-gray-500 mb-6">
      <a href="/collections" class="hover:text-dead-gold transition-colors">Collections</a>
      <span>/</span>
      <span class="text-gray-300">{badge.name}</span>
    </div>

    <div class="flex flex-wrap items-start justify-between gap-4 mb-6">
      <div>
        <h1 class="text-3xl font-bold text-dead-gold mb-1">{badge.name}</h1>
        <p class="text-gray-400">
          {releases.length} release{releases.length !== 1 ? 's' : ''}
        </p>
      </div>

      <!-- Sort toggle — pure vanilla JS, no React needed -->
      {hasVolumes && (
        <div class="flex items-center gap-1 bg-dead-card border border-dead-border rounded-lg p-1">
          <button
            id="sort-date"
            onclick="setSort('date')"
            class="px-3 py-1.5 text-xs font-medium rounded-md bg-dead-teal text-white transition-colors"
          >
            By Date
          </button>
          <button
            id="sort-volume"
            onclick="setSort('volume')"
            class="px-3 py-1.5 text-xs font-medium rounded-md text-gray-400 hover:text-white transition-colors"
          >
            By Volume
          </button>
        </div>
      )}
    </div>

    <!-- Release grids: two pre-sorted lists, JS swaps visibility -->
    {(['date', 'volume'] as const).map((sortKey) => {
      const items = sortKey === 'date' ? byDate : byVolume;
      return (
        <div
          id={`grid-${sortKey}`}
          class={`grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-3 ${sortKey === 'volume' ? 'hidden' : ''}`}
        >
          {items.map((release) => {
            const displayDate = release.isRange
              ? `${release.startDate} → ${release.endDate}`
              : release.dates.slice(0, 3).join(', ') + (release.dates.length > 3 ? ' …' : '');

            return (
              <div class="p-3 rounded-xl border border-dead-border bg-dead-card flex flex-col hover:border-dead-gold/50 transition-colors group">
                {release.imageUrl && (
                  <div class="aspect-square mb-2 overflow-hidden rounded-lg bg-dead-bg border border-dead-border">
                    <img
                      src={release.imageUrl}
                      alt={release.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                      loading="lazy"
                      onerror="this.parentElement.style.display='none'"
                    />
                  </div>
                )}

                <h3 class="text-xs font-semibold text-white mb-1 leading-tight group-hover:text-dead-gold transition-colors">
                  {release.title}
                </h3>

                <!-- Show date links -->
                {release.dates.length > 0 && (
                  <div class="text-[10px] text-gray-500 mb-2 flex flex-wrap gap-x-1.5 gap-y-0.5">
                    {release.dates.slice(0, 6).map((d) => {
                      const show = showByDate.get(d);
                      return show
                        ? <a href={`/shows/${show.band}/${show.slug}`} class="text-dead-gold hover:text-white hover:underline">{d}</a>
                        : <span class="text-gray-600">{d}</span>;
                    })}
                    {release.dates.length > 6 && <span class="text-gray-600">+{release.dates.length - 6} more</span>}
                  </div>
                )}
                {release.isRange && (
                  <div class="text-[10px] text-gray-500 mb-2">{displayDate}</div>
                )}

                <!-- Action links -->
                <div class="mt-auto flex flex-col gap-1">
                  {release.dates[0] && !release.isRange && (() => {
                    const show = showByDate.get(release.dates[0]);
                    return show
                      ? <a href={`https://relisten.net/grateful-dead/${release.dates[0].replace(/-/g,'/')}`} target="_blank" rel="noopener noreferrer" class="text-[10px] text-dead-teal-light hover:text-white transition-colors">Relisten ↗</a>
                      : null;
                  })()}
                  <a
                    href={release.discUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-[10px] text-dead-teal-light hover:text-white transition-colors"
                  >
                    {isArchive ? 'Archive.org ↗' : 'Details on DeadDisc ↗'}
                  </a>
                </div>
              </div>
            );
          })}
        </div>
      );
    })}
  </div>
</Layout>

{hasVolumes && (
  <script>
    function setSort(sort: 'date' | 'volume') {
      const grids = { date: document.getElementById('grid-date'), volume: document.getElementById('grid-volume') };
      const btns  = { date: document.getElementById('sort-date'),  volume: document.getElementById('sort-volume') };
      for (const [key, el] of Object.entries(grids)) {
        el?.classList.toggle('hidden', key !== sort);
      }
      for (const [key, el] of Object.entries(btns)) {
        el?.classList.toggle('bg-dead-teal', key === sort);
        el?.classList.toggle('text-white',   key === sort);
        el?.classList.toggle('text-gray-400', key !== sort);
      }
    }
    // Expose globally so onclick handlers can reach it, and re-expose after
    // any View Transition navigation lands on a collection page with volumes
    function exposeSetSort() {
      (window as any).setSort = setSort;
    }
    document.addEventListener('astro:page-load', exposeSetSort);
  </script>
)}
