---
import Layout from '@/components/Layout.astro';
import ShowList, { type ShowRow } from '@/components/islands/ShowList';
import { getYears, getShowsByYear } from '@/lib/shows';
import { buildReleasesDateIndex, getCollectionsForDate } from '@/lib/releases';

export async function getStaticPaths() {
  const years = await getYears();
  return years.map(({ year }) => ({ params: { year } }));
}

const { year } = Astro.params;
const [shows, releaseIndex] = await Promise.all([
  getShowsByYear(year),
  buildReleasesDateIndex(),
]);

// Enrich shows with collection info for badge rendering in the island
const showRows: ShowRow[] = shows.map((s) => ({
  slug: s.slug,
  band: s.band,
  date: s.date,
  year: s.year,
  venue: s.venue,
  city: s.city,
  state: s.state,
  country: s.country,
  collections: getCollectionsForDate(s.date, releaseIndex),
}));

const gdShows = showRows.filter((s) => s.band === 'gd');
const dacShows = showRows.filter((s) => s.band === 'dac');
---

<Layout title={`${year} Shows`}>
  <div class="mx-auto max-w-7xl px-4 py-10">
    <!-- Breadcrumb -->
    <div class="flex items-center gap-2 text-sm text-gray-500 mb-6">
      <a href="/years" class="hover:text-dead-gold transition-colors">Years</a>
      <span>/</span>
      <span class="text-gray-300">{year}</span>
    </div>

    <h1 class="text-3xl font-bold text-dead-gold mb-1">{year}</h1>
    <p class="text-gray-400 mb-8">
      {shows.length} show{shows.length !== 1 ? 's' : ''}
      {dacShows.length > 0 && ` (${gdShows.length} GD, ${dacShows.length} Dead & Co)`}
    </p>

    {gdShows.length > 0 && (
      <div class={dacShows.length > 0 ? 'mb-12' : ''}>
        {dacShows.length > 0 && (
          <h2 class="text-xl font-semibold text-dead-gold mb-4">Grateful Dead</h2>
        )}
        <!-- ShowList is a React island: handles pagination + release filter -->
        <ShowList shows={gdShows} showFilter client:load />
      </div>
    )}

    {dacShows.length > 0 && (
      <div>
        <h2 class="text-xl font-semibold text-teal-400 mb-4">Dead &amp; Company</h2>
        <ShowList shows={dacShows} client:load />
      </div>
    )}
  </div>
</Layout>
