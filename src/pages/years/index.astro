---
import Layout from '@/components/Layout.astro';
import { getYears } from '@/lib/shows';

const years = await getYears();

// Group by decade
const decades = new Map<string, typeof years>();
for (const y of years) {
  const decade = `${y.year.slice(0, 3)}0s`;
  if (!decades.has(decade)) decades.set(decade, []);
  decades.get(decade)!.push(y);
}
---

<Layout title="Shows by Year">
  <div class="mx-auto max-w-7xl px-4 py-10">
    <h1 class="text-3xl font-bold text-dead-gold mb-2">Shows by Year</h1>
    <p class="text-gray-400 mb-8">{years.length} years of live music</p>

    {Array.from(decades.entries()).map(([decade, decadeYears]) => (
      <div class="mb-10">
        <h2 class="text-lg font-semibold text-purple-400 mb-3 border-b border-dead-border pb-2">
          {decade}
        </h2>
        <div class="grid grid-cols-3 sm:grid-cols-5 md:grid-cols-7 lg:grid-cols-9 gap-2">
          {decadeYears.map(({ year, gdCount, dacCount }) => {
            const total = gdCount + dacCount;
            return (
              <a
                href={`/years/${year}`}
                class="flex flex-col items-center p-3 rounded-lg border border-dead-border bg-dead-card hover:border-dead-gold hover:bg-dead-card-hover transition-all group"
              >
                <span class="text-base font-bold text-white group-hover:text-dead-gold transition-colors">
                  {year}
                </span>
                <span class="text-xs text-gray-500 group-hover:text-gray-300 mt-0.5">
                  {total} shows
                </span>
                {dacCount > 0 && (
                  <span class="text-[9px] text-teal-400 mt-0.5">+D&amp;C</span>
                )}
              </a>
            );
          })}
        </div>
      </div>
    ))}
  </div>
</Layout>
