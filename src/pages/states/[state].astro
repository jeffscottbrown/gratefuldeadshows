---
import Layout from '@/components/Layout.astro';
import ShowList, { type ShowRow } from '@/components/islands/ShowList';
import { getStates, getShowsByState } from '@/lib/shows';
import { buildReleasesDateIndex, getCollectionsForDate } from '@/lib/releases';

export async function getStaticPaths() {
  const states = await getStates();
  return states.map(({ state }) => ({ params: { state } }));
}

const state = Astro.params.state;
const [shows, releaseIndex] = await Promise.all([getShowsByState(state), buildReleasesDateIndex()]);

const showRows: ShowRow[] = shows.map((s) => ({
  slug: s.slug, band: s.band, date: s.date, year: s.year,
  venue: s.venue, city: s.city, state: s.state, country: s.country,
  collections: getCollectionsForDate(s.date, releaseIndex),
}));
---

<Layout title={state}>
  <div class="mx-auto max-w-7xl px-4 py-10">
    <div class="flex items-center gap-2 text-sm text-gray-500 mb-6">
      <a href="/states" class="hover:text-dead-gold transition-colors">States</a>
      <span>/</span>
      <span class="text-gray-300">{state}</span>
    </div>
    <h1 class="text-3xl font-bold text-dead-gold mb-1">{state}</h1>
    <p class="text-gray-500 mb-8 text-sm">{shows.length} show{shows.length !== 1 ? 's' : ''}</p>
    <ShowList shows={showRows} showFilter client:load />
  </div>
</Layout>
