---
import Layout from '@/components/Layout.astro';
import { getStats } from '@/lib/shows';

const stats = await getStats();

function fmt(n: number) { return n.toLocaleString('en-US'); }

const navCards = [
  { href: '/years',       label: 'Browse by Year',       icon: '📅', desc: 'Explore shows decade by decade, from 1965 through 1995 and Dead & Co beyond.',         color: 'from-purple-900/60 to-purple-800/30 border-purple-700/40',  accent: 'text-purple-300' },
  { href: '/cities',      label: 'Browse by City',        icon: '🏙️', desc: 'Find every city the Dead ever played, from Menlo Park to London.',                    color: 'from-teal-900/60 to-teal-800/30 border-teal-700/40',        accent: 'text-teal-300' },
  { href: '/states',      label: 'Browse by State',       icon: '🇺🇸', desc: 'Explore shows by US state and region.',                                              color: 'from-emerald-900/60 to-emerald-800/30 border-emerald-700/40', accent: 'text-emerald-300' },
  { href: '/countries',   label: 'Browse by Country',     icon: '🌍', desc: 'The Dead went global — see every country on the tour map.',                           color: 'from-amber-900/60 to-amber-800/30 border-amber-700/40',      accent: 'text-amber-300' },
  { href: '/songs',       label: 'Browse by Song',        icon: '🎸', desc: 'Track every song ever played and when it appeared in the setlist.',                   color: 'from-rose-900/60 to-rose-800/30 border-rose-700/40',         accent: 'text-rose-300' },
  { href: '/collections', label: 'Official Releases',     icon: '💿', desc: "Explore release collections like Dick's Picks, Dave's Picks, and box sets.",          color: 'from-blue-900/60 to-blue-800/30 border-blue-700/40',         accent: 'text-blue-300' },
  { href: '/search',      label: 'Search Shows',          icon: '🔍', desc: 'Filter shows by year, country, and city.',                                            color: 'from-gray-900/60 to-gray-800/30 border-gray-700/40',          accent: 'text-gray-300' },
  { href: '/birthday',    label: 'Birthday Shows',        icon: '🎂', desc: 'Discover every show played on your birthday.',                                        color: 'from-indigo-900/60 to-indigo-800/30 border-indigo-700/40',   accent: 'text-indigo-300' },
  { href: '/about',       label: 'About',                 icon: '🌈', desc: 'About the site and how to contribute.',                                               color: 'from-indigo-900/60 to-indigo-800/30 border-indigo-700/40',   accent: 'text-indigo-300' },
];
---

<Layout title="Home">
  <!-- Hero -->
  <section class="relative w-full overflow-hidden" style="min-height: 420px">
    <div class="absolute inset-0 bg-hero-gradient" />
    <img
      src="/images/hero.png"
      alt="Dancing Grateful Dead bears traveling the globe"
      class="absolute inset-0 w-full h-full object-cover opacity-80"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-dead-bg/40 via-transparent to-dead-bg" />
    <div class="relative z-10 flex flex-col items-center justify-center text-center px-4 py-20">
      <h1 class="text-5xl md:text-7xl font-bold text-white drop-shadow-lg">
        <span class="text-dead-gold">Grateful</span>{' '}
        <span class="text-white">Dead</span>{' '}
        <span class="text-dead-teal-light">Shows</span>
      </h1>
      <p class="mt-4 text-lg md:text-xl text-gray-300 max-w-xl drop-shadow">
        A searchable archive of almost every concert — every city, every song, every year.
        Now including Dead &amp; Company.
      </p>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="border-y border-dead-border bg-dead-card/60">
    <div class="mx-auto max-w-7xl px-4 py-4">
      <div class="flex flex-wrap justify-center divide-x divide-dead-border">
        {[
          { value: fmt(stats.gdShows),     label: 'GD Shows' },
          { value: fmt(stats.dacShows),    label: 'D&C Shows' },
          { value: fmt(stats.songs),       label: 'Distinct Songs' },
          { value: fmt(stats.performances),label: 'Performances' },
          { value: fmt(stats.venues),      label: 'Venues' },
          { value: fmt(stats.cities),      label: 'Cities' },
          { value: fmt(stats.countries),   label: 'Countries' },
        ].map(({ value, label }) => (
          <div class="text-center px-4 py-2">
            <div class="text-2xl font-bold text-dead-gold">{value}</div>
            <div class="text-xs text-gray-400 uppercase tracking-widest mt-0.5">{label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Nav cards -->
  <section class="mx-auto max-w-7xl px-4 py-12">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {navCards.map((card) => (
        <a
          href={card.href}
          class={`group rounded-xl border bg-gradient-to-br ${card.color} p-6 hover:scale-[1.02] transition-all duration-200 hover:shadow-lg hover:shadow-black/30`}
        >
          <div class="text-3xl mb-3">{card.icon}</div>
          <h2 class={`text-lg font-semibold ${card.accent} group-hover:text-white transition-colors`}>
            {card.label}
          </h2>
          <p class="mt-1 text-sm text-gray-400 group-hover:text-gray-300 transition-colors">
            {card.desc}
          </p>
        </a>
      ))}
    </div>
  </section>
</Layout>
