---
import Layout from '@/components/Layout.astro';
import ShowList, { type ShowRow } from '@/components/islands/ShowList';
import { getVenues, getShowsByVenue } from '@/lib/shows';
import { buildReleasesDateIndex, getCollectionsForDate } from '@/lib/releases';

export async function getStaticPaths() {
  const venues = await getVenues();
  return venues.map(({ venue }) => ({ params: { venue } }));
}

const venue = Astro.params.venue;
const [shows, releaseIndex] = await Promise.all([getShowsByVenue(venue), buildReleasesDateIndex()]);

const showRows: ShowRow[] = shows.map((s) => ({
  slug: s.slug, band: s.band, date: s.date, year: s.year,
  venue: s.venue, city: s.city, state: s.state, country: s.country,
  collections: getCollectionsForDate(s.date, releaseIndex),
}));

const firstShow = shows[0];
const location = [firstShow?.city, firstShow?.state, firstShow?.country].filter(Boolean).join(', ');
---

<Layout title={venue}>
  <div class="mx-auto max-w-7xl px-4 py-10">
    <h1 class="text-3xl font-bold text-white mb-1">{venue}</h1>
    {location && <p class="text-gray-400 mb-1">{location}</p>}
    <p class="text-gray-500 mb-8 text-sm">{shows.length} show{shows.length !== 1 ? 's' : ''}</p>
    <ShowList shows={showRows} showFilter client:load />
  </div>
</Layout>
