---
import Layout from '@/components/Layout.astro';
import { getCountries } from '@/lib/shows';
import { countryLabel } from '@/lib/format';

const countries = await getCountries();
---

<Layout title="Shows by Country">
  <div class="mx-auto max-w-7xl px-4 py-10">
    <h1 class="text-3xl font-bold text-dead-gold mb-2">Shows by Country</h1>
    <p class="text-gray-400 mb-8">{countries.length} countries visited</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
      {countries.map(({ country, count }) => (
        <a
          href={`/countries/${encodeURIComponent(country)}`}
          class="flex items-center justify-between px-5 py-4 rounded-xl border border-dead-border bg-dead-card hover:border-dead-gold hover:bg-dead-card-hover transition-all group"
        >
          <div>
            <div class="text-white font-medium group-hover:text-dead-gold transition-colors">
              {countryLabel(country)}
            </div>
            <div class="text-xs text-gray-500 mt-0.5">{country}</div>
          </div>
          <div class="text-right">
            <div class="text-lg font-bold text-dead-gold">{count}</div>
            <div class="text-xs text-gray-500">shows</div>
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>
