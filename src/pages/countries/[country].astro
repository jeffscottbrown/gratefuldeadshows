---
import Layout from '@/components/Layout.astro';
import ShowList, { type ShowRow } from '@/components/islands/ShowList';
import { getCountries, getShowsByCountry } from '@/lib/shows';
import { buildReleasesDateIndex, getCollectionsForDate } from '@/lib/releases';
import { countryLabel } from '@/lib/format';

export async function getStaticPaths() {
  const countries = await getCountries();
  return countries.map(({ country }) => ({ params: { country } }));
}

const country = Astro.params.country;
const [shows, releaseIndex] = await Promise.all([getShowsByCountry(country), buildReleasesDateIndex()]);

const showRows: ShowRow[] = shows.map((s) => ({
  slug: s.slug, band: s.band, date: s.date, year: s.year,
  venue: s.venue, city: s.city, state: s.state, country: s.country,
  collections: getCollectionsForDate(s.date, releaseIndex),
}));
---

<Layout title={countryLabel(country)}>
  <div class="mx-auto max-w-7xl px-4 py-10">
    <div class="flex items-center gap-2 text-sm text-gray-500 mb-6">
      <a href="/countries" class="hover:text-dead-gold transition-colors">Countries</a>
      <span>/</span>
      <span class="text-gray-300">{countryLabel(country)}</span>
    </div>
    <h1 class="text-3xl font-bold text-dead-gold mb-1">{countryLabel(country)}</h1>
    <p class="text-gray-500 mb-8 text-sm">{shows.length} show{shows.length !== 1 ? 's' : ''}</p>
    <ShowList shows={showRows} showFilter client:load />
  </div>
</Layout>
